# Copy this file to .env and fill in values

# Required
NOTION_KEY=
NOTION_PARENT_PAGE_ID=

# Optional
# Version of Notion API to target (defaults to 2022-06-28)
NOTION_VERSION=2022-06-28

# Verbose upload logging (set to 1 to enable)
DEBUG_UPLOADS=0

# Parent page for the cleanup helper (if you use npm run cleanup)
NOTION_CLEANUP_PARENT_PAGE_ID=

